{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "sonata",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.2",
  "scripts": {
    "dev": "bun --cwd packages/cli src/index.ts",
    "typecheck": "bun turbo typecheck",
    "lint": "bun turbo lint",
    "lint:fix": "bun turbo lint:fix",
    "format": "bun turbo format",
    "format:check": "bun turbo format:check",
    "build": "bun turbo build",
    "test": "echo 'do not run tests from root' && exit 1"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@opencode-ai/plugin": "1.2.11",
      "@opencode-ai/sdk": "1.2.11",
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.9",
      "@types/yargs": "17.0.33",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "drizzle-kit": "0.31.6",
      "drizzle-orm": "0.44.5",
      "turbo": "2.5.6",
      "typescript": "5.8.2",
      "ulid": "2.4.0",
      "xdg-basedir": "5.1.0",
      "zod": "4.1.8"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
